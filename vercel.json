{
  "version": 2,
  "builds": [
    {
      "src": "taller-app/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api-app/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api-app/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "taller-app/$1",
      "continue": true
    }
  ]
}